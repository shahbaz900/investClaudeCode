# SmartStockPicker Production Environment Variables
# Copy these to Vercel Environment Variables Dashboard

# ============================================
# MISTRAL AI API
# ============================================
# Get from: https://console.mistral.ai/api-keys/
NEXT_PUBLIC_MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================
# FINNHUB STOCK API
# ============================================
# Get from: https://finnhub.io/dashboard
NEXT_PUBLIC_FINNHUB_API_KEY=your_finnhub_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get from: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# BACKEND SERVER CONFIGURATION
# ============================================
# Backend API URL for frontend calls
NEXT_PUBLIC_API_URL=http://localhost:8000
# For production, change to your backend URL:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# Backend internal settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
ENVIRONMENT=production

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Next.js configuration
NEXT_PUBLIC_APP_NAME=SmartStockPicker
NEXT_PUBLIC_APP_URL=https://invest-claude-code.vercel.app
# For production, change to your frontend domain:
# NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com

# ============================================
# INSTRUCTIONS FOR VERCEL DEPLOYMENT
# ============================================
# 1. Go to your Vercel project dashboard
# 2. Click "Settings" → "Environment Variables"
# 3. Add each variable below with your actual API keys:
#    - NEXT_PUBLIC_MISTRAL_API_KEY
#    - MISTRAL_API_KEY
#    - NEXT_PUBLIC_FINNHUB_API_KEY
#    - FINNHUB_API_KEY
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - SUPABASE_SERVICE_ROLE_KEY
#    - NEXT_PUBLIC_API_URL (set to your backend URL)
#    - NEXT_PUBLIC_APP_URL (set to your Vercel domain)
# 4. Select appropriate environments: Production, Preview, Development
# 5. Redeploy your application
